# =============================================================================
# Frontend environment variables (Vite — must be prefixed with VITE_)
# Copy this file to .env and fill in your values.
# =============================================================================

# Supabase project URL (Settings → API → Project URL)
VITE_SUPABASE_URL=https://arwgbowbhgjqnkfwqbvf.supabase.co

# Supabase anon / public key (Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# =============================================================================
# Backend environment variables (Railway server)
# Set these in your Railway project dashboard → Variables
# =============================================================================

# Port Railway will inject automatically — leave blank locally or set to 3000
PORT=3000

# Node environment
NODE_ENV=production

# Supabase URL (same as above — used server-side if needed)
SUPABASE_URL=https://arwgbowbhgjqnkfwqbvf.supabase.co

# Supabase service-role key (Settings → API → service_role secret)
# WARNING: never expose this key in the frontend
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Railway backend URL (for reference)
RAILWAY_URL=https://vibe-music-hub-production.up.railway.app

# URL of your deployed Netlify frontend (for CORS allow-list)
FRONTEND_URL=https://your-app.netlify.app
